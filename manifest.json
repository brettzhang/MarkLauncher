{
  "manifest_version": 3,
  "name": "MarkLauncher - Bookmark Launcher",
  "description": "A simple and efficient new tab bookmark launcher with folder navigation on the left and bookmark details on the right",
  "version": "1.0.0",
  "default_locale": "en",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "favicon"
  ],
  "web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "MarkLauncher Settings"
  }
}